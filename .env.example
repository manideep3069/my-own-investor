# Copy to .env and fill in. All keys are optional in Phase 0 except IBKR (for live data).
# Everything here is a SECRET — .env is gitignored.

# --- Interactive Brokers (override settings.yaml if desired) ---
# MOI_IBKR__PORT=7497
# MOI_IBKR__CLIENT_ID=17
# MOI_IBKR__ACCOUNT=DU1234567

# --- SEC EDGAR (required for 13F/Form-4 collectors) ---
# The SEC requires a contact identity on API requests:
# MOI_EDGAR_IDENTITY=Jane Doe jane@example.com

# --- Data source API keys (Phase 1) ---
# MOI_QUIVER_API_KEY=
# MOI_UNUSUALWHALES_API_KEY=
# MOI_FRED_API_KEY=

# --- Notifications (Phase 3) ---
# MOI_TELEGRAM_BOT_TOKEN=
# MOI_TELEGRAM_CHAT_ID=

# --- Execution rails (Phase 4) — defaults shown; change deliberately ---
# The executor only trades paper accounts (DU...) unless this is explicitly true.
# With a live account, `moi execute` additionally asks for interactive confirmation.
# MOI_ALLOW_LIVE=false
# MOI_MAX_ORDER_USD=8000
# MOI_MAX_DAILY_USD=30000
# MOI_IBKR__READONLY=true
# Arming rail: when set, live execution also requires `moi unlock` (or the dashboard
# unlock), which opens a timed window. Generate with: openssl rand -hex 24
# MOI_TRADING_UNLOCK_KEY=
# MOI_TRADING_UNLOCK_MINUTES=60
